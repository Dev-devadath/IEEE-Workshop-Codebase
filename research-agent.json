    {
      "parameters": {
        "jsCode": "const raw = $json.content.parts[0].text;\n\nconst queries = JSON.parse(raw.trim());\n\nconst search_query = queries\n  .map(q => `all:${q}`)\n  .join(' OR ');\n\nreturn [\n  {\n    json: {\n      queries,\n      search_query\n    }\n  }\n];"
      },
