    },
    {
      "parameters": {
        "jsCode": "let entries = $json.feed?.entry ?? [];\n\n// Normalize to array\nentries = Array.isArray(entries) ? entries : [entries];\n\nreturn entries.map(e => ({\n  json: {\n    title: e.title || '',\n    summary: e.summary || '',\n    link: e.id || '',\n    published: e.published || '',\n    authors: Array.isArray(e.author)\n      ? e.author.map(a => a.name)\n      : e.author?.name\n        ? [e.author.name]\n        : []\n  }\n}));"
      },
